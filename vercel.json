{
  "installCommand": "pnpm install --prod=false",
  "buildCommand": "pnpm run vercel-build",
  "framework": null,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
